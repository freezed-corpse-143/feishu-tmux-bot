{
  "name": "feishu-tmux-bot",
  "version": "1.0.0",
  "description": "Feishu bot to send commands to tmux",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/"
  },
  "dependencies": {
    "@fastify/multipart": "^10.0.0",
    "@larksuiteoapi/node-sdk": "^1.0.0",
    "fastify": "^5.0.0",
    "iconv-lite": "^0.7.2",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "smol-toml": "^1.6.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
